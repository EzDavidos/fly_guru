# ── Supabase ────────────────────────────────────────────────────────────────
# Скопируй этот файл в .env.local и подставь значения из дашборда Supabase.
# Дашборд: https://supabase.com/dashboard → выбери проект.

# Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Project Settings → API Keys → anon / public key.
# Публичный ключ, попадает в браузер. Доступ ограничивается RLS-политиками (Этап 3).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API Keys → service_role / secret key.
# СЕКРЕТНЫЙ ключ, обходит RLS. Только сервер (seed-скрипты, серверные операции).
# НИКОГДА не префиксуй его NEXT_PUBLIC_ и не коммить реальное значение.
SUPABASE_SERVICE_ROLE_KEY=

# ── Telegram-уведомления о новых заявках ────────────────────────────────────
# Необязательно. Если оба поля пустые — уведомления просто не отправляются,
# заявки всё равно сохраняются в базу.
#
# TELEGRAM_BOT_TOKEN — токен бота от @BotFather (напиши ему /newbot).
# TELEGRAM_CHAT_ID    — id чата, куда слать. Узнать: напиши своему боту любое
#   сообщение, затем открой в браузере
#   https://api.telegram.org/bot<ТОКЕН>/getUpdates и возьми значение chat.id.
# Оба — СЕКРЕТНЫЕ, без префикса NEXT_PUBLIC_. В проде задаются в env Vercel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
